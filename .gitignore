```gitignore
# Dependencies
node_modules/
# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp
# Logs
*.log
# Environment
.env
.env.local
*.env.*
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
# Build artifacts
dist/
build/
*.so
*.o
*.a
*.obj
*.out
# Coverage
coverage/
htmlcov/
.coverage
# Tests
.pytest_cache/
.mypy_cache/
# System files
.DS_Store
Thumbs.db
```